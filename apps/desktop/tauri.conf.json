{
  "$schema": "https://raw.githubusercontent.com/nicedozie4u/tauri-apps/refs/heads/main/crates/tauri-cli/schema.json",
  "productName": "SparkLoom",
  "version": "0.1.0",
  "identifier": "com.sparkloom.app",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @sparkloom/desktop-ui dev",
    "beforeBuildCommand": "pnpm --filter @sparkloom/desktop-ui build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SparkLoom",
        "width": 1024,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "SparkLoom"
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "frameworks": [],
      "entitlements": "Entitlements.plist"
    }
  }
}
